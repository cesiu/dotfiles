\usepackage{tikz, datetime, textpos}
\usefonttheme[onlymath]{serif}

% NOTE: These are based on Cal Poly colors as of Winter 2026;
%       see also https://ucm.calpoly.edu/color-guidelines.
\definecolor{MedianGreen}{RGB}{21,71,52}
\definecolor{MedianSycamore}{RGB}{120,159,144}
\definecolor{MedianSage}{RGB}{220,246,233}
\definecolor{MedianGold}{RGB}{198,146,20}
\definecolor{MedianSand}{RGB}{162,159,134}
\definecolor{MedianBeige}{RGB}{239,238,222}

\setbeamercolor*{title page header}{fg=white}
\setbeamercolor*{title}{fg=MedianSage}
\setbeamercolor*{author}{fg=white}
\setbeamercolor*{date}{fg=white}
\setbeamercolor*{item}{fg=MedianSand}
\setbeamercolor*{frametitle}{fg=MedianGreen}
\setbeamercolor*{block title}{fg=white, bg=MedianSycamore}
\setbeamercolor*{block title example}{fg=white, bg=MedianSand}
\setbeamercolor*{block body}{bg=MedianSage}
\setbeamercolor*{block body example}{bg=MedianBeige}
\setbeamercolor*{section in toc}{fg=black}
\setbeamercolor*{section page}{fg=white}
\setbeamercolor*{page number in head/foot}{fg=gray}

\setbeamerfont{section page}{size=\LARGE}
\setbeamerfont{title}{size=\LARGE}
\setbeamerfont{author}{size=\Large}
\setbeamerfont{date}{size=\Large}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}{\insertcaption}
\setbeamertemplate{items}[square]
\setbeamertemplate{sections/subsections in toc}[square]

\setbeamertemplate{itemize item}{
    \tikz{\draw[color=MedianSand, fill=MedianBeige, very thick] rectangle (0.15, 0.15);}
}

\setbeamertemplate{itemize subitem}{
    \tikz{\draw[color=MedianSand, fill=MedianBeige, very thick] rectangle (0.15, 0.15);}
}

\setbeamertemplate{enumerate item}{
    \tikz{\draw[color=MedianSand, fill=MedianSand, very thick] rectangle (0.15, 0.15)
        node[midway, text=MedianBeige, inner sep=0cm, outer sep=0cm]{\tiny\textbf{\insertenumlabel}};}
}

\setbeamertemplate{enumerate subitem}{
    \tikz{\draw[color=MedianSand, fill=MedianSand, very thick] rectangle (0.15, 0.15)
        node[midway, text=MedianBeige, inner sep=0cm, outer sep=0cm]{\tiny\textbf{\insertsubenumlabel}};}
}

\defbeamertemplate{description item}{bulleted}{
    \hspace{1em}\tikz{\draw[color=MedianSand, fill=MedianBeige, very thick] rectangle (0.15, 0.15);}
    ~\color{black}\textbf{\insertdescriptionitem}~\hfill
}

\newenvironment{xplainframe}{\bgroup\setbeamertemplate{background}{}\begin{frame}[plain]}{\end{frame}\egroup}

\setbeamertemplate{footline}{
    \usebeamercolor[fg]{page number in head/foot}
    \usebeamerfont{page number in head/foot}
    \hfill\raisebox{0.2cm}{\insertframenumber\,/\,\inserttotalframenumber}\hspace{0.2cm}
}

\setbeamertemplate{background}{
    \begin{tikzpicture}
        \useasboundingbox (0, 0) rectangle (\the\paperwidth, \the\paperheight);
        \ifnum\thepage>1\relax % Not the title page
              \fill[color=MedianGold] (0, 7.57) rectangle (0.77, 7.82);
              \fill[color=MedianGreen] (0.87, 7.57) rectangle (\the\paperwidth, 7.82);
        \else % Title page
            \fill[color=MedianGreen] (0, 1.2) rectangle (\the\paperwidth, \the\paperheight);
            \fill[color=MedianGold] (0, 0.1) rectangle (3.36, 1.1);
            \fill[color=MedianGreen] (3.46, 0.1) rectangle (\the\paperwidth, 1.1);
        \fi
    \end{tikzpicture}
}

\setbeamertemplate{title page}{
    \begin{textblock*}{12cm} (2.7cm, 2.7cm)
        \begin{beamercolorbox}[wd=8cm]{title page header}
            \usebeamerfont{title}\usebeamercolor{title}\inserttitle%
        \end{beamercolorbox}%
    \end{textblock*}
    \begin{textblock*}{3cm} (-0.92cm, 4.81cm)
        \begin{beamercolorbox}{date}
            \hfill\usebeamerfont{date}\insertdate%
        \end{beamercolorbox}
    \end{textblock*}
    \begin{textblock*}{9cm} (2.73cm, 4.81cm)
        \begin{beamercolorbox}{author}
            \usebeamerfont{author}\insertauthor%
        \end{beamercolorbox}
    \end{textblock*}
}

\newcommand{\sectionframe}{{
    \setbeamertemplate{background}{
        \begin{tikzpicture}
            \useasboundingbox (0,0) rectangle (\the\paperwidth, \the\paperheight);
            \fill[color=MedianGreen] (0, 0) rectangle (\the\paperwidth, 5.74);
            \fill[color=MedianGold] (0, 5.84) rectangle (0.77, 6.84);
            \fill[color=MedianGreen] (0.87, 5.84) rectangle (\the\paperwidth, 6.84);
            \fill[color=MedianGreen] (0, 6.94) rectangle (\the\paperwidth, \the\paperheight);
        \end{tikzpicture}
    }
    \frame{\sectionpage}
}}

\setbeamertemplate{section page}{
    \begin{textblock*}{12cm} (0.11cm, -0.96cm)
        \begin{beamercolorbox}{section page}
            \insertsectionhead
        \end{beamercolorbox}
    \end{textblock*}
}

\setbeamertemplate{frametitle}{
    \vspace{0.13cm}
    \begin{beamercolorbox}{frametitle}
        \hspace{0.03cm}\strut\insertframetitle\strut%
    \end{beamercolorbox}
}
